FROM python:3.13-slim

COPY --from=ghcr.io/astral-sh/uv:0.7.12 /uv /uvx /bin/

WORKDIR /workspace

ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/workspace/.venv \
    PYTHONPATH=/workspace/api \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

COPY pyproject.toml uv.lock ./
COPY db/pyproject.toml db/pyproject.toml
COPY api/pyproject.toml api/pyproject.toml
COPY worker/pyproject.toml worker/pyproject.toml

RUN uv sync --frozen --package code-review-api --no-install-workspace --no-install-project

COPY db db
COPY api api

RUN uv sync --frozen --package code-review-api --no-dev

ENV PATH="/workspace/.venv/bin:$PATH"

WORKDIR /workspace/api

EXPOSE 8000

CMD ["sh", "-c", "cd /workspace/db && alembic upgrade head && cd /workspace/api && uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload"]
