FROM python:3.13-slim

COPY --from=ghcr.io/astral-sh/uv:0.7.12 /uv /uvx /bin/

RUN apt-get update \
    && apt-get install -y --no-install-recommends git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/workspace/.venv \
    PYTHONPATH=/workspace/worker \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

COPY pyproject.toml uv.lock ./
COPY db/pyproject.toml db/pyproject.toml
COPY api/pyproject.toml api/pyproject.toml
COPY worker/pyproject.toml worker/pyproject.toml

RUN uv sync --frozen --package code-review-worker --no-install-workspace --no-install-project

COPY db db
COPY worker worker

RUN uv sync --frozen --package code-review-worker --no-dev

ENV PATH="/workspace/.venv/bin:$PATH"

WORKDIR /workspace/worker

EXPOSE 8001

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8001", "--reload"]
