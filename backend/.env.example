# ================================
# App
# ================================
LOG_LEVEL=INFO
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# ================================
# Database
# ================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=code_review

# ================================
# Repository
# ================================
CLONE_DIR=/tmp/repos

# ================================
# Source discovery
# ================================
SOURCE_MAX_FILE_BYTES=1000000
SOURCE_ALLOWED_EXTENSIONS=.py,.tsx
SOURCE_IGNORED_DIRECTORIES=.git,.venv,__pycache__,node_modules,.next,build,dist,vendor

# ================================
# Azure OpenAI
# ================================
AZURE_OPENAI_BASE_URL=your-azure-openai-base-url
AZURE_OPENAI_CHAT_API_KEY=your-azure-openai-chat-api-key
AZURE_OPENAI_CHAT_MODEL=your-azure-openai-chat-model
AZURE_OPENAI_EMBEDDING_API_KEY=your-azure-openai-embedding-api-key
AZURE_OPENAI_EMBEDDING_MODEL=your-azure-openai-embedding-model

# ================================
# LLM review
# ================================
LLM_MAX_CONCURRENCY=5