# Backend application configuration
# Copy to backend/.env and fill in required values.

# --- Required ---

# Local dev: use localhost. Docker Compose overrides this at runtime.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/code_review

# Comma-separated browser origins allowed by CORS
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

AZURE_OPENAI_BASE_URL=https://your-resource.services.ai.azure.com/openai/v1
AZURE_OPENAI_CHAT_API_KEY=your-chat-api-key
AZURE_OPENAI_CHAT_MODEL=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_API_KEY=your-embedding-api-key
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Optional (defaults shown) ---

# CLONE_DIR=/tmp/repos
# LOG_LEVEL=INFO
# API_PREFIX=/api
# MAX_FILES_TO_REVIEW=15
# MAX_FILE_SIZE_BYTES=50000
# MAX_TOTAL_CHARS=120000
# CHUNK_SIZE_CHARS=12000
